# ===== 文本文件换行符与 diff 驱动 =====
* text=auto

*.c     text diff=cpp
*.cc    text diff=cpp
*.cxx   text diff=cpp
*.cpp   text diff=cpp
*.cpi   text diff=cpp
*.c++   text diff=cpp
*.hpp   text diff=cpp
*.h     text diff=cpp
*.h++   text diff=cpp
*.hh    text diff=cpp
*.ui    text diff=cpp
*.qrc   text diff=cpp
*.qss   text diff=cpp
*.pro   text diff=cpp
*.pri   text diff=cpp

# ===== 编译产物与二进制文件 =====
# Compiled Object files
*.slo   binary
*.lo    binary
*.o     binary
*.obj   binary

# Precompiled Headers
*.gch   binary
*.pch   binary

# Compiled Dynamic libraries
*.so    binary
*.dylib binary
*.dll   binary

# Compiled Static libraries
*.lai   binary
*.la    binary
*.a     binary
*.lib   binary

# Executables
*.exe   binary
*.out   binary
*.app   binary

# Qt moc 生成文件
*.moc   binary

# 常见二进制资源
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
# 其他 Live2D/资源文件如有需要可继续添加

# ===== Linguist 语言统计配置 =====
# 将所有 C/C++ 相关扩展名强制归为 C++ (避免被拆分为 C 和 C++)
*.c     linguist-language=C++
*.cc    linguist-language=C++
*.cxx   linguist-language=C++
*.cpp   linguist-language=C++
*.cpi   linguist-language=C++
*.c++   linguist-language=C++
*.h     linguist-language=C++
*.hpp   linguist-language=C++
*.h++   linguist-language=C++
*.hh    linguist-language=C++
*.ui    linguist-language=C++
*.qrc   linguist-language=C++
*.qss   linguist-language=C++
*.pro   linguist-language=C++
*.pri   linguist-language=C++

# Python 文件标记为 Python（可根据需要调整）
# 如果你希望 Python 参与统计但只是次要语言，保留下面这一行
# *.py    linguist-language=Python

# 如果你希望工具脚本不影响主语言比例，可将工具目录标记为 vendored
# scripts/** linguist-vendored

# 排除文档、资源等无关目录
docs/**   linguist-vendored
assets/** linguist-vendored
scripts/** linguist-vendored=true

# ===== 资源文件中的其他语言忽略 =====
# 自动生成的资源文件（如 Qt rcc 输出的 Python、QRC 中引用的文件）
*.py    linguist-vendored=true
*.ts    linguist-vendored=true
*.qm    linguist-vendored=true
*.json  linguist-vendored=true
*.xml   linguist-vendored=true
*.yml   linguist-vendored=true
*.yaml  linguist-vendored=true
*.svg   linguist-vendored=true

